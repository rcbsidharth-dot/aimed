# AI Doctor in a Box — Monorepo

NODE_ENV=development

# Frontend (apps/web)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend (apps/api)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aidoctor
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/aidoctor
REDIS_URL=redis://localhost:6379
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
GROQ_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_MAPS_API_KEY=
CORS_ORIGINS=http://localhost:3000
MOCK_AI=true
RATE_LIMIT_PER_MINUTE=60
ADMIN_EMAILS=admin@example.com
SECRET_KEY=change-me-in-production-use-long-random-string
